{
  "name": "itam-pro",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter @itam-pro/frontend dev",
    "dev:backend": "pnpm --filter @itam-pro/backend dev",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "build:frontend": "pnpm --filter @itam-pro/frontend build",
    "build:backend": "pnpm --filter @itam-pro/backend build",
    "db:migrate": "pnpm --filter @itam-pro/backend db:migrate",
    "db:seed": "pnpm --filter @itam-pro/backend db:seed",
    "db:studio": "pnpm --filter @itam-pro/backend db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "dependencies": {
    "@creativoma/liquid-glass": "^1.2.0"
  }
}
