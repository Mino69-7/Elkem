# ─── Microsoft Entra ID (Azure AD) ──────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ─── Base de données PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql://itam_user:itam_password@localhost:5432/itam_db

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
# AUTH_MODE : "sso" pour Microsoft Entra, "local" pour dev/démo
AUTH_MODE=local
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Sécurité ────────────────────────────────────────────────
# IMPORTANT : Changer ces valeurs en production (min 32 caractères)
JWT_SECRET=change-me-in-production-min-32-chars-required
SESSION_SECRET=change-me-in-production-min-32-chars-required

# ─── Microsoft Graph (Intune) ─────────────────────────────────
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_TENANT_ID=your-tenant-id
