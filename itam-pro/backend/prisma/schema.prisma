generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTILISATEURS ────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  azureId       String?   @unique
  email         String    @unique
  displayName   String
  passwordHash  String?
  role          Role      @default(VIEWER)
  avatar        String?
  department    String?
  jobTitle      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedDevices        Device[]         @relation("AssignedUser")
  auditLogs              AuditLog[]
  createdPurchaseOrders  PurchaseOrder[]  @relation("POCreatedBy")

  // Index : recherche utilisateurs actifs, filtres par rôle
  @@index([isActive])
  @@index([role])
  @@index([isActive, role])
}

enum Role {
  MANAGER
  TECHNICIAN
  VIEWER
}

// ─── APPAREILS ───────────────────────────────────────────────

model Device {
  id              String          @id @default(cuid())

  // Identifiants
  assetTag        String?
  serialNumber    String          @unique
  intuneDeviceId  String?         @unique
  intuneUrl       String?

  // Informations matérielles
  type            DeviceType
  brand           String
  model           String
  processor       String?
  ram             String?
  storage         String?
  screenSize      String?
  color           String?

  // Clavier & région
  keyboardLayout   KeyboardLayout  @default(AZERTY_FR)
  keyboardLanguage String?

  // Statut & localisation
  status          DeviceStatus    @default(IN_STOCK)
  condition       DeviceCondition @default(GOOD)
  location        String?
  site            String?

  // Attribution utilisateur
  assignedUserId  String?
  assignedUser    User?           @relation("AssignedUser", fields: [assignedUserId], references: [id])
  assignedAt      DateTime?

  // Cycle de vie
  purchaseDate          DateTime?
  warrantyExpiry        DateTime?
  lastMaintenanceDate   DateTime?
  retiredAt             DateTime?
  maintenanceDeadline   DateTime?

  // Données financières
  purchasePrice   Float?
  supplier        String?
  invoiceNumber   String?

  // Données Intune
  intuneLastSync  DateTime?
  intuneOsVersion String?
  intuneCompliant Boolean?
  intuneLastSeen  DateTime?
  intuneEnrolled  DateTime?
  intuneOsName    String?

  // Champs réseau (PC Labo / Indus)
  hostname        String?
  vlan            String?
  ipAddress       String?
  macAddress      String?
  bitlocker       String?

  // Écran — docking intégrée
  hasDocking      Boolean?

  // Smartphone / Tablette
  imei            String?

  // Métadonnées
  notes           String?         @db.Text
  qrCode          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Modèle du catalogue (référence directe)
  modelId     String?
  deviceModel DeviceModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  // Commande d'achat associée
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Relations
  auditLogs       AuditLog[]
  maintenanceLogs MaintenanceLog[]
  attachments     Attachment[]

  // ─── Index de performance ────────────────────────────────────
  // Filtres simples très fréquents
  @@index([status])
  @@index([type])
  @@index([assignedUserId])
  @@index([site])
  // Filtres combinés (page Utilisateurs : type + assigned, Stock : status + type)
  @@index([status, type])
  @@index([assignedUserId, type])
  @@index([status, updatedAt])
  // groupBy stock-summary (DeviceModel controller)
  @@index([status, model])
  // FK relations (Prisma ne crée pas d'index sur les FK en Postgres)
  @@index([purchaseOrderId])
  @@index([modelId])
  // Tris courants
  @@index([updatedAt])
  @@index([createdAt])
  // Garanties expirant (Dashboard)
  @@index([warrantyExpiry])
  @@index([status, warrantyExpiry])
}

enum DeviceType {
  LAPTOP
  DESKTOP
  THIN_CLIENT
  LAB_WORKSTATION
  SMARTPHONE
  TABLET
  MONITOR
  KEYBOARD
  MOUSE
  HEADSET
  DOCKING_STATION
  PRINTER
  OTHER
}

enum DeviceStatus {
  ORDERED
  IN_STOCK
  ASSIGNED
  PENDING_RETURN
  IN_MAINTENANCE
  LOANER
  LOST
  STOLEN
  RETIRED
}

enum DeviceCondition {
  NEW
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum KeyboardLayout {
  AZERTY_FR
  QWERTY_US
  QWERTY_UK
  QWERTY_ES
  QWERTY_IT
  QWERTY_NO
  QWERTY_NL
  QWERTZ_DE
  QWERTZ_CH
  QWERTY_RU
  QWERTY_TR
  QWERTY_AR
  OTHER
}

// ─── AUDIT LOG ───────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  deviceId    String
  device      Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  action      AuditAction
  fieldName   String?
  oldValue    String?
  newValue    String?
  comment     String?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  // Index CRITIQUES — chargés à chaque ouverture de fiche device + dashboard activity feed
  @@index([deviceId])
  @@index([deviceId, createdAt])  // historique trié par device
  @@index([userId])               // FK + possible filtre par technicien
  @@index([action])               // filtres par type d'action
  @@index([createdAt])            // dashboard : activité récente ORDER BY createdAt DESC
}

enum AuditAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  UNASSIGNED
  DELETED
  INTUNE_SYNCED
  MAINTENANCE_ADDED
  ATTACHMENT_ADDED
}

// ─── MAINTENANCE ─────────────────────────────────────────────

model MaintenanceLog {
  id          String    @id @default(cuid())
  deviceId    String
  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type        String
  description String    @db.Text
  cost        Float?
  provider    String?
  startDate   DateTime
  endDate     DateTime?
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // Index : chargé à chaque onglet Maintenance d'une fiche device
  @@index([deviceId])
  @@index([deviceId, createdAt])
  @@index([resolved])             // filtres maintenances ouvertes/fermées
}

// ─── PIÈCES JOINTES ──────────────────────────────────────────

model Attachment {
  id          String    @id @default(cuid())
  deviceId    String
  device      Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int?
  createdAt   DateTime  @default(now())

  // Index : chargé à chaque ouverture de fiche device
  @@index([deviceId])
}

// ─── MODÈLES D'APPAREILS ─────────────────────────────────────

model DeviceModel {
  id              String          @id @default(cuid())
  name            String
  type            DeviceType
  brand           String          @default("Dell")
  processor       String?
  ram             String?
  storage         String?
  screenSize      String?
  keyboardLayout  KeyboardLayout? @default(AZERTY_FR)
  notes           String?
  isActive        Boolean         @default(true)
  order           Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  purchaseOrders PurchaseOrder[]
  devices        Device[]

  @@unique([name, type])
  // Index : filtres catalogue (isActive très fréquent), tri display
  @@index([isActive])
  @@index([type, isActive])   // listModels : WHERE isActive=true AND type=?
  @@index([type])             // stockSummary ORDER BY type
  @@index([order])            // tri d'affichage ORDER BY order ASC
}

// ─── ALERTES STOCK ───────────────────────────────────────────

model StockAlert {
  id          String      @id @default(cuid())
  deviceType  DeviceType
  threshold   Int         @default(3)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Index : getTriggered filtre WHERE isActive=true, upsert sur deviceType
  @@index([deviceType])
  @@index([isActive])
}

// ─── COMMANDES D'ACHAT ───────────────────────────────────────

model PurchaseOrder {
  id              String      @id @default(cuid())
  reference       String      @unique
  deviceModelId   String
  deviceModel     DeviceModel @relation(fields: [deviceModelId], references: [id])
  quantity        Int
  receivedCount   Int         @default(0)
  status          POStatus    @default(PENDING)
  expectedAt      DateTime?
  notes           String?
  createdById     String
  createdBy       User        @relation("POCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  devices         Device[]

  // Index : listOrders (status NOT IN ...), listHistory (ORDER BY createdAt), FK relations
  @@index([status])
  @@index([status, createdAt])   // liste active triée
  @@index([createdAt])           // historique trié ORDER BY createdAt DESC
  @@index([deviceModelId])       // FK DeviceModel
  @@index([createdById])         // FK User (manager)
}

enum POStatus {
  PENDING
  PARTIAL
  COMPLETE
  CANCELLED
}
